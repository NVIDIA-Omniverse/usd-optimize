            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.054852307, 0.050917752, 0.050917752)
                float inputs:metallic = 0.29999998
                token outputs:displacement
                token outputs:surface
            }
        }

