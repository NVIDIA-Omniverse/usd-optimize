            uniform token[] xformOpOrder = ["xformOp:transform"]
        }

        def Material "Material"
        {
            token outputs:displacement.connect = </Cubes/CubePrimvarReader2/Material/PreviewShader.outputs:displacement>
            token outputs:surface.connect = </Cubes/CubePrimvarReader2/Material/PreviewShader.outputs:surface>

