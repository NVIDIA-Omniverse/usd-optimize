#usda 1.0
(
    defaultPrim = "World"
    endTimeCode = 100
    metersPerUnit = 0.01
    startTimeCode = 0
    timeCodesPerSecond = 60
    upAxis = "Y"
)

def Xform "World" (
    variants = {
        string test = "a"
    }
    prepend variantSets = ["test"]
)
{
    def Cube "Cube"
    {
        double3 xformOp:translate
        double3 xformOp:rotateXYZ
        double3 xformOp:scale
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
        double size
    }

    variantSet "test" = {
        "a" {
            over "Cube"
            {
                double3 xformOp:translate = (30, 20, -70)
                double3 xformOp:rotateXYZ = (10, 20, 30)
                double3 xformOp:scale = (0.8, 1.7, 1.3)
                float3[] extent = [(-5.0, -5.0, -5.0), (5.0, 5.0, 5.0)]
                double size = 10.0
            }
        }
        "b" {
            over "Cube"
            {
                double3 xformOp:translate = (-80, 10, 5)
                double3 xformOp:rotateXYZ = (-30, 10, -20)
                double3 xformOp:scale = (1.7, 1.3, 0.8)
                float3[] extent = [(-50.0, -50.0, -50.0), (50.0, 50.0, 50.0)]
                double size = 100.0
            }
        }
    }
}
