#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 0.01
    upAxis = "Y"
    doc = """Deduplication-only test scene for fuzzy mode.

    Contains identical mesh geometry (same topology and local-space points)
    at different translations only. No deinstancing or GeomSubset split;
    use to validate fuzzy deduplication (same shape, different transform).
    """
)

def Xform "World"
{
    # Identical square pyramid mesh at different positions (translation only).
    # Fuzzy dedup should recognize them as the same geometry.

    def Xform "Dedup1"
    {
        double3 xformOp:translate = (0, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        def Mesh "Pyramid"
        {
            float3[] extent = [(-0.5, -0.5, -0.5), (0.5, 0.5, 0.5)]
            int[] faceVertexCounts = [4, 3, 3, 3, 3]
            int[] faceVertexIndices = [0, 1, 2, 3, 0, 1, 4, 1, 2, 4, 2, 3, 4, 3, 0, 4]
            point3f[] points = [
                (-0.5, -0.5, -0.5), (0.5, -0.5, -0.5), (0.5, -0.5, 0.5), (-0.5, -0.5, 0.5),
                (0, 0.5, 0)
            ]
            uniform token subdivisionScheme = "none"
        }
    }

