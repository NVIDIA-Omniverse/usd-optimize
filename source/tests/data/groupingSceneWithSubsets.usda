    def Scope "Looks"
    {
        def Material "lambert2"
        {
            token outputs:mdl:surface.connect = </World/Looks/lambert2/Shader.outputs:out>
            token outputs:surface.connect = </World/Looks/lambert2/lambert2PreviewSurface.outputs:surface>

            def Shader "lambert2PreviewSurface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (1, 0, 0)
                token outputs:surface
            }

            def Shader "Shader" (
                kind = "Material"
            )
            {
                uniform token info:implementationSource = "sourceAsset"
                uniform asset info:mdl:sourceAsset = @OmniPBR.mdl@
                uniform token info:mdl:sourceAsset:subIdentifier = "OmniPBR"
                color3f inputs:diffuse_color_constant = (1, 0, 0)
                token outputs:out
            }
        }

        def Material "lambert3"
        {
            token outputs:mdl:surface.connect = </World/Looks/lambert3/Shader.outputs:out>
            token outputs:surface.connect = </World/Looks/lambert3/lambert3PreviewSurface.outputs:surface>

            def Shader "lambert3PreviewSurface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0, 0, 1)
                token outputs:surface
            }

            def Shader "Shader" (
                kind = "Material"
            )
            {
                uniform token info:implementationSource = "sourceAsset"
                uniform asset info:mdl:sourceAsset = @OmniPBR.mdl@
                uniform token info:mdl:sourceAsset:subIdentifier = "OmniPBR"
                color3f inputs:diffuse_color_constant = (0, 0, 1)
                token outputs:out
            }
        }
    }
}

