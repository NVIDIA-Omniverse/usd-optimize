            uniform token[] xformOpOrder = ["xformOp:transform"]
        }

        def Material "Material4"
        {
            token outputs:displacement.connect = </Cubes/CubeRed1/Material4/PreviewShader.outputs:displacement>
            token outputs:surface.connect = </Cubes/CubeRed1/Material4/PreviewShader.outputs:surface>

            def Shader "PreviewShader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (1, 0, 0)
                token outputs:displacement
                token outputs:surface
            }
        }
    }

    def Xform "CubeRed2"
    {
        def Cube "Cube5Shape" (
            prepend apiSchemas = ["MaterialBindingAPI"]
