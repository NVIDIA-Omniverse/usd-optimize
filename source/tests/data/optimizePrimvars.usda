    def Mesh "ArbitraryPrimvars"
    {
        uniform bool doubleSided = 1
        float3[] extent = [(-5, 0, 7), (5, 0, 17)]
        int[] faceVertexCounts = [4, 4, 4, 4]
        int[] faceVertexIndices = [0, 1, 4, 3, 1, 2, 5, 4, 3, 4, 7, 6, 4, 5, 8, 7]
