    def Material "MaterialRed"
    {
        token outputs:displacement.connect = </World/MaterialRed/Shader.outputs:displacement>
        token outputs:surface.connect = </World/MaterialRed/Shader.outputs:surface>

        def Shader "Shader"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (1, 0, 0)
            token outputs:displacement
            token outputs:surface
        }
    }

