            token outputs:surface.connect = </World/Looks/Material5/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0, 1, 1)
                token outputs:displacement
                token outputs:surface
            }
        }
    }

